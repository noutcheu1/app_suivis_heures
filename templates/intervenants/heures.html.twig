{% extends 'base.html.twig' %}

{% block title %}Heures de {{ user.nom_Candidats }}{% endblock %}

{% block body %}
<h1>Liste des heures enregistrées par 
    <a href="{{ path('intervenant_panel', {'id': user.id}) }}">
        {{ user.nom_Candidats }} {{ user.prenom_Candidats }}
    </a>
</h1>

<ul class="menu">
    <li>
        <a href="{{ path('intervenant_suivie', {'id': user.id}) }}">
            <img src="{{ asset('assets/icons/calendar.png') }}" alt="ajouter">
            Ajouter
        </a>
    </li>
</ul>

<table id="table" class="table table-striped table-bordered">
    <thead class="thead-dark" >
        <tr>
            <th>Nom de famille</th>
            <th>Date de prestation</th>
            <th class="d-none d-md-table-cell">Heure de début</th>
            <th class="d-none d-md-table-cell">Heure de fin</th>
            <th>Type de prestation</th>
            <th class="d-none d-md-table-cell">Ajouter le</th>
            <th class="d-none d-md-table-cell">Dernière modification</th>
            <th class="d-none d-md-table-cell">Supprimer / Récupérer</th>
            <th class="d-block d-md-table-cell">Voir détaille</th>
        </tr>
    </thead>
    <tbody>
    {% for presta in prestations %}
        <tr>
            <td>
                {% if presta.numFam != 9998 %}
                <a href="{{ path('famille_profile', {'id': presta.numFam}) }}">
                    {{ presta.nomFam }}
                </a>
                {% else %}
                    {{ presta.nomFam }}
                {% endif %}
            </td>
            <td>{{ presta.datePresta|date('d/m/Y') }}</td>
            <td class="d-none d-md-table-cell">{{ presta.heureDebutPresta|date('H:i') }}</td>
            <td class="d-none d-md-table-cell">{{ presta.heureFinPresta|date('H:i') }}</td>
            <td >{{ presta.typePresta }}</td>
            <td class="d-none d-md-table-cell">{{ presta.ajouterLe }}</td>
            <td class="d-none d-md-table-cell">{{ presta.modifierLe }}
                <a href="{{ path('intervenant_suivie', {'id': user.id, 'edite': presta.id}) }}" class="btn-vert">Modifier</a>
            </td>
            <td class="d-none d-md-table-cell">
                {% if presta.desactiver == 1 %}
                    <a href="{{ path('intervenant_heures', {'id': user.id, 'recup': presta.id}) }}" class="btn-vert">Récupérer</a>
                {% else %}
                    <a href="{{ path('intervenant_heures', {'id': user.id, 'supp': presta.id}) }}" class="btn-rouge">X</a>
                {% endif %}
            </td>
            <td class="d-block d-md-table-cell">
                <input type="button" class="btn btn-info voir-detail" value="voir" data-target="{{ loop.index }}" />
            </td>
        </tr>
    {% endfor %}
    </tbody>
    
</table>

{% endblock %}

{% block modal %}
{{ parent() }}
{% for presta in prestations %}
    <div class="modal" id="modalData{{ loop.index }}" tabindex="-1" >
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Détail prestation {{ presta.nomFam }}</h5>
                </div>
                <div class="modal-body">
                    <table class="table table-striped table-bordered">
                        <tr>
                            <td> Nom de famille : </td>
                            <td> {{ presta.nomFam }} </td>
                        </tr>
                        <tr>
                            <td> Date de prestation : </td>
                            <td> {{ presta.datePresta|date('d/m/Y') }} </td>
                        </tr>
                        <tr>
                            <td> Heure de début : </td>
                            <td> {{ presta.heureDebutPresta }} </td>
                        </tr>
                        <tr>
                            <td> Heure de fin </td>
                            <td> {{ presta.heureFinPresta }} </td>
                        </tr>
                        <tr>
                            <td> Type de prestation </td>
                            <td> {{ presta.nomFam }} </td>
                        </tr>
                        <tr>
                            <td> Ajouter le </td>
                            <td> {{ presta.ajouterLe }} </td>
                        </tr>
                        <tr>
                            <td> Modification </td>
                            <td> 
                                {{ presta.modifierLe }}
                                <a href="{{ path('intervenant_suivie', {'id': user.id, 'edite': presta.id}) }}" class="btn-vert">Modifier</a>
                            </td>
                        </tr>
                        <tr>
                            <td> Supprimer / Récupérer </td>
                            <td> 
                            
                                {% if presta.desactiver == 1 %}
                                    <a href="{{ path('intervenant_heures', {'id': user.id, 'recup': presta.id}) }}" class="btn-vert">Récupérer</a>
                                {% else %}
                                    <a href="{{ path('intervenant_heures', {'id': user.id, 'supp': presta.id}) }}" class="btn-rouge">X</a>
                                {% endif %}
                            
                             </td>
                        </tr>
                    </table>
                    <button class="btn btn-primary" aria-label="Close" id="modalDataClose{{ loop.index }}" >
                         Fermer 
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endfor %}
    
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
const compare = (ids, asc) => (row1, row2) => {
  const tdValue = (row, ids) => row.children[ids].textContent;
  const tri = (v1, v2) => v1 !== '' && v2 !== '' && !isNaN(v1) && !isNaN(v2) ? v1 - v2 : v1.toString().localeCompare(v2);
  return tri(tdValue(asc ? row1 : row2, ids), tdValue(asc ? row2 : row1, ids));
};

const tbody = document.querySelector('tbody');
const thx = document.querySelectorAll('th');
const trxb = tbody.querySelectorAll('tr');

thx.forEach(th => {
  th.addEventListener('click', function() {
    // Déterminer l'index de la colonne
    const index = Array.from(thx).indexOf(th);
    
    // Alterner l'ordre de tri
    this.asc = !this.asc;
    
    let sortedRows;
    if (index === 1) {
      // Colonne 2 : tri des dates FR
      const parseDateFR = (str) => {
        const parts = str.split('/');
        if (parts.length !== 3) return null;
        const [day, month, year] = parts.map(Number);
        return new Date(year, month - 1, day);
      };

      sortedRows = Array.from(trxb).sort((row1, row2) => {
        const v1 = row1.children[index].textContent.trim();
        const v2 = row2.children[index].textContent.trim();
        const d1 = parseDateFR(v1);
        const d2 = parseDateFR(v2);
        if (d1 && d2 && !isNaN(d1) && !isNaN(d2)) {
          return this.asc ? d1 - d2 : d2 - d1;
        }
        return 0; // si date invalide, ne change rien
      });

    } else {
      // Autres colonnes : tri classique
      sortedRows = Array.from(trxb).sort(compare(index, this.asc));
    }
    // Réinsérer les lignes triées
    sortedRows.forEach(tr => tbody.appendChild(tr));
    
    // Supprimer les flèches de tous les th
    thx.forEach(th => {
      let arrow = th.querySelector('.arrow');
      if (arrow) arrow.remove();
    });
    
    // Ajouter la flèche à la colonne triée
    const arrow = document.createElement('span');
    arrow.classList.add('arrow');
    arrow.textContent = this.asc ? '▲' : '▼'; // ▲ = croissant, ▼ = décroissant
    th.appendChild(arrow);
  });
});

document.querySelectorAll('.voir-detail').forEach(btn => {
    console.log("oki");
    btn.addEventListener('click', () => {
        const modalTarget = document.getElementById(`modalData${btn.dataset.target}`);
        const modalTargetClose = document.getElementById(`modalData${btn.dataset.target}`)
        const modal = new bootstrap.Modal(modalTarget);

        modalTargetClose.addEventListener('click', () => {
            modal.hide();
        });
        
        modal.show();
    });
});
</script>
{% endblock %}
