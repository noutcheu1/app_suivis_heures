{% extends 'base.html.twig' %}

{% block title %}Paramètres {{ type }} {% endblock %}
{% block body %}

<div class="">
    <h1> Paramètres de  {{ user.nom }} {{ user.prenom }} </h1>

    <form>
        <input type="hidden" id="csrf_token" value="{{ csrf_token('change_password') }}">

        <h2> Modifier le mot de passe </h2>
        <div id="error" class="alert alert-danger d-none"></div>
        <div id="success" class="alert alert-success d-none" role="alert"></div>

        <div class="form-group">
            <label for="currentPass">Mot de passe actuel</label>
            <input type="password" class="form-control" id="currentPass">
        </div>

        <div class="form-group">
            <label for="pass1">Mot de passe</label>
            <input type="password" class="form-control" id="pass1">

            <label for="pass2">Verification de mot de passe</label>
            <input type="password" class="form-control" id="pass2">
        </div>

        <button type="submit" class="btn btn-primary" id="submitBtn">
            Envoyer
        </button>
    </form>
    
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    const ID = {{ id }};
</script>

<script src="{{ asset('/assets/js/settings.js') }}"></script>
{% endblock %}